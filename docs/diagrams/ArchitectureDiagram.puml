@startuml
!include <office/Concepts/globe_internet>
!include <office/Concepts/documents>
!include <office/Users/user>
!include style.puml

Package " "<<Rectangle>>{
    Class UI UI_COLOR
    Class Logic LOGIC_COLOR
    Class Storage STORAGE_COLOR
    Class Model MODEL_COLOR
    Class Main #grey
    Class Commons LOGIC_COLOR_T2
}

Class "<$user>" as User MODEL_COLOR_T2
Class "<$documents>" as File UI_COLOR_T1


User -right..> UI
UI -right[#green]-> Logic
UI -down[#green]-> Model
Logic -right[#blue]-> Storage
Logic -down[#blue]-> Model
Main -left[#grey]-> UI
Main -down[#grey]-> Logic
Main -down[#grey]-> Storage
Main -down[#grey]-> Model
Main -down[hidden]-> Commons
Storage -left[STORAGE_COLOR].> Model
Storage -right[STORAGE_COLOR]..> File

@enduml
