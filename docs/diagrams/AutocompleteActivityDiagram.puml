@startuml
!include style.puml

start
:User types text in CommandBox;

if () then ([text is empty])
    :Return all command words;
else ([else])
    if () then ([no space in text])
        :Filter command words\nby typed prefix;
    else ([else])
        if () then ([valid command word])
            switch (Command type?)
            case (add)
                if () then ([flag typed])
                    if () then ([typing a "/" token])
                        :Suggest matching unused\nprefixes for the flag type;
                    else ([else])
                        :No suggestions;
                    endif
                else ([else])
                    :Suggest type flags\n(-student / -tutorial);
                endif
            case (delete / list)
                :Suggest type flags;
            case (find)
                :Suggest find flags;
            case (edit)
                if () then ([typing a "/" token])
                    :Suggest matching unused\nedit prefixes;
                else ([else])
                    :No suggestions;
                endif
            case (others)
                :No suggestions;
            endswitch
        else ([else])
            :No suggestions;
        endif
    endif
endif

:Display suggestions\nin Popup;
stop

@enduml
